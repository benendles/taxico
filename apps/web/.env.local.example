# Taxico web client configuration

# Base URL of the Taxico API (REST + Socket.IO)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Mapbox GL access token (https://account.mapbox.com/access-tokens/).
# Without it the map falls back to a live SVG schematic — paste your pk.* token to
# enable real Mapbox tiles.
NEXT_PUBLIC_MAPBOX_TOKEN=
